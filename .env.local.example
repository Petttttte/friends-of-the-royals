# Friends of the Royals - Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ============================================================
# STRIPE PAYMENT INTEGRATION
# ============================================================
# Get these from your Stripe Dashboard: https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_...) during development
# Use live keys (pk_live_...) for production

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# ============================================================
# SITE URL (for SEO and absolute URLs)
# ============================================================
NEXT_PUBLIC_SITE_URL=https://friendsoftheroyals.ca

# ============================================================
# CONTACT FORM (optional - if using a form backend)
# ============================================================
# If using Formspree: https://formspree.io
NEXT_PUBLIC_FORMSPREE_ID=YOUR_FORMSPREE_FORM_ID

# If using EmailJS
NEXT_PUBLIC_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY
